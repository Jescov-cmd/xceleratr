{
  "name": "xceleratr",
  "version": "1.3.1",
  "description": "Mouse acceleration and sensitivity utility for Windows and macOS",
  "author": "Jescov-cmd",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently \"vite\" \"electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs"
  },
  "build": {
    "appId": "com.xceleratr.app",
    "productName": "Xceleratr",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "public/tray.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Jescov-cmd",
      "repo": "xceleratr"
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "koffi": "^2.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
